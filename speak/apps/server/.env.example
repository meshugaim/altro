# PersonaPlex GPU server (full-duplex speech-to-speech, Moshi-based).
# Run it on a GPU host: `python -m moshi.server --ssl <dir>` (see DEPLOY.md).
#
# Public WebSocket base the browser connects to directly. Include the port.
# Use wss:// when the page is served over HTTPS (browsers require it for mic).
PERSONAPLEX_WS_URL=wss://your-gpu-host:8998

# Default voice embedding (filename from the server's voices dir). See VOICES
# in packages/client for the shipped set (NATF*/NATM*/VARF*/VARM*).
PERSONAPLEX_VOICE=NATF0.pt

# Default persona / role prompt sent at the start of each conversation.
PERSONAPLEX_PERSONA=You are a wise and friendly teacher. Answer questions or provide advice in a clear and engaging way.

# Optional: comma-separated voice filenames to expose in the UI picker.
# Defaults to the full shipped set when unset.
# PERSONAPLEX_VOICES=NATF0.pt,NATM0.pt,VARF0.pt
