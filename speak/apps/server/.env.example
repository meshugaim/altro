# Required: NVIDIA API key from https://build.nvidia.com (Generate API Key)
NVIDIA_API_KEY=nvapi-...

# LLM — defaults to NVIDIA's hosted OpenAI-compatible endpoint. Works as-is with the key above.
NVIDIA_LLM_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# ASR (Riva / Parakeet) — defaults to a locally-running NIM container on port 9000.
# To run locally:
#   docker run --gpus all -p 9000:9000 nvcr.io/nim/nvidia/parakeet-1-1b-rnnt-multilingual-asr:latest
# To use NVIDIA's hosted version, copy the per-model URL from the "Deploy" tab on
# https://build.nvidia.com/nvidia/parakeet-1_1b-rnnt-multilingual-asr/deploy
NVIDIA_ASR_URL=http://localhost:9000
NVIDIA_ASR_LANGUAGE=en-US

# TTS (Magpie) — defaults to a locally-running NIM container on port 9001.
# To run locally:
#   docker run --gpus all -p 9001:9000 nvcr.io/nim/nvidia/magpie-tts-multilingual:latest
# To use NVIDIA's hosted version, copy the per-model URL from build.nvidia.com.
NVIDIA_TTS_URL=http://localhost:9001
NVIDIA_TTS_VOICE=Magpie-Multilingual.EN-US.Aria
NVIDIA_TTS_LANGUAGE=en-US

# System prompt for the assistant
SPEAK_SYSTEM_PROMPT=You are Speak, a concise spoken assistant. Reply in 1-3 short sentences suitable for text-to-speech. No markdown, no lists.
